# EDI Reconciliation Tool — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env — it is gitignored.

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------

# Full Postgres connection URL.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/cinderhaven

# Alternative: individual Postgres components (used if DATABASE_URL is unset)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=cinderhaven
# POSTGRES_USER=user
# POSTGRES_PASSWORD=password

# ---------------------------------------------------------------------------
# Dashboard (optional)
# ---------------------------------------------------------------------------

# Port for the FastAPI server (default: 8000)
# PORT=8000

# ---------------------------------------------------------------------------
# Pipeline (optional)
# ---------------------------------------------------------------------------

# Random seed for the corpus generator (default: 42)
# CORPUS_SEED=42

# Corpus output directory (default: corpus/output)
# CORPUS_OUTPUT=corpus/output
